APP_NAME="Sondaggi Moderni"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Fuso orario: scadenze e campo datetime-local sono letti come ora locale in questa zona (Italia).
APP_TIMEZONE=Europe/Rome

# Salt per hash IP / rate limit sondaggi pubblici (obbligatorio in produzione)
APP_RESPONSE_SALT=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite (solo artisan serve locale) oppure MySQL (Docker o produzione)
DB_CONNECTION=sqlite
# Con `docker compose` da questa cartella: nel container web usare DB_HOST=db;
# da host (artisan / IDE): DB_HOST=127.0.0.1
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=sondaggi_db
# DB_USERNAME=sondaggi_user
# DB_PASSWORD=sondaggi_pass

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
